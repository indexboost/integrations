<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>

    <!-- ==========================================
         IndexBoost Render — IIS URL Rewrite
         Requires:
           - URL Rewrite module (iis.net/downloads/microsoft/url-rewrite)
           - Application Request Routing (ARR) (iis.net/downloads/microsoft/application-request-routing)
         ========================================== -->

    <rewrite>
      <rules>

        <!-- Rule 1: Skip static assets — let IIS serve them directly -->
        <rule name="IndexBoost Skip Static" stopProcessing="true">
          <match url=".*\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|pdf|zip|gz|mp4|webm|mp3|ogg|wav|flac|avi|mov|wmv|swf|json|xml|txt|csv|rss|atom|map)(\?.*)?" />
          <conditions logicalGrouping="MatchAll" />
          <action type="None" />
        </rule>

        <!-- Rule 2: Forward crawler requests to IndexBoost render service -->
        <rule name="IndexBoost Render Crawlers" stopProcessing="true">
          <match url="(.*)" />
          <conditions logicalGrouping="MatchAll" trackAllCaptures="false">
            <!-- Match known web crawlers -->
            <add input="{HTTP_USER_AGENT}" pattern="googlebot|bingbot|yandex|baiduspider|facebookexternalhit|twitterbot|rogerbot|linkedinbot|embedly|quora|pinterest|slackbot|vkShare|W3C_Validator|redditbot|applebot|whatsapp|flipboard|tumblr|bitlybot|skypeuripreview|nuzzel|discordbot|google-read-aloud|duckduckbot|kakaotalk|headlesschrome|lighthousebot|seobilitybot|seokicks-robot|ahrefsbot|semrushbot" />
          </conditions>
          <!-- Proxy to IndexBoost render service including the original URL as query param -->
          <action
            type="Rewrite"
            url="https://render.getindexboost.com/?url=https://{HTTP_HOST}/{R:1}"
            appendQueryString="false"
          />
        </rule>

      </rules>

      <!-- Outbound rule: inject X-INDEXBOOST-TOKEN header on proxied requests -->
      <outboundRules>
        <preConditions>
          <preCondition name="IsCrawlerRequest">
            <add input="{HTTP_USER_AGENT}" pattern="googlebot|bingbot|yandexbot|baiduspider|facebookexternalhit|twitterbot|rogerbot|linkedinbot|headlesschrome|ahrefsbot|semrushbot" />
          </preCondition>
        </preConditions>
      </outboundRules>

    </rewrite>

    <!-- ARR: add authentication header on forwarded requests -->
    <!-- NOTE: IIS ARR does not support adding request headers via web.config directly.
         Use the ARR Server Farm with a health probe to set the X-INDEXBOOST-TOKEN header,
         OR use an HttpModule / ISAPI filter, OR proxy through a minimal ASP.NET middleware.

         The recommended approach for IIS is the ASP.NET Core middleware:
         See integrations/aspnet/ -->

    <!-- Alternative: use a custom HTTP Module. See README for details. -->

  </system.webServer>
</configuration>
