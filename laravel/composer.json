{
    "name": "indexboost/laravel",
    "description": "IndexBoost Render middleware for Laravel",
    "keywords": ["indexboost", "render", "seo", "crawler", "laravel"],
    "homepage": "https://getindexboost.com/docs/integrations/laravel",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": ">=8.1",
        "illuminate/http": ">=10.0",
        "illuminate/support": ">=10.0"
    },
    "require-dev": {
        "orchestra/testbench": ">=8.0",
        "phpunit/phpunit": ">=10.0"
    },
    "autoload": {
        "psr-4": {
            "IndexBoost\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "IndexBoost\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "IndexBoost\\Laravel\\IndexBoostServiceProvider"
            ],
            "aliases": {
                "IndexBoost": "IndexBoost\\Laravel\\Facades\\IndexBoost"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
