{
  "name": "@indexboost/nuxt",
  "version": "1.0.0",
  "description": "IndexBoost Render module for Nuxt 3",
  "keywords": ["indexboost", "render", "seo", "crawler", "nuxt", "nuxt3", "nuxtjs"],
  "homepage": "https://getindexboost.com/docs/integrations/nuxt",
  "repository": {
    "type": "git",
    "url": "https://github.com/indexboost/integrations"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/module.mjs",
      "require": "./dist/module.cjs",
      "types": "./dist/types.d.ts"
    }
  },
  "main": "./dist/module.cjs",
  "module": "./dist/module.mjs",
  "types": "./dist/types.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "nuxt-module-build build",
    "prepare": "nuxt-module-build build --stub",
    "dev": "nuxi dev playground"
  },
  "peerDependencies": {
    "nuxt": ">=3.0.0"
  },
  "devDependencies": {
    "@nuxt/kit": "^3.0.0",
    "@nuxt/module-builder": "^0.8.0",
    "@nuxt/schema": "^3.0.0",
    "nuxt": "^3.0.0"
  }
}
