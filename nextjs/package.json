{
  "name": "@indexboost/next",
  "version": "1.0.0",
  "description": "IndexBoost Render middleware for Next.js (App Router & Pages Router)",
  "keywords": ["indexboost", "render", "seo", "crawler", "nextjs", "middleware"],
  "homepage": "https://getindexboost.com/docs/integrations/nextjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/indexboost/integrations"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch"
  },
  "peerDependencies": {
    "next": ">=14.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "next": "^15.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
